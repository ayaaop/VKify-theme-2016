{extends "../@layout.latte"}

{block title}
    {if $create}
        {_create_app}
    {else}
        {_edit_app}
    {/if}
{/block}

{block bodyScripts}
    {if !$create}
        <script src="/themepack/vkify16/{$theme->getVersion()}/resource/js/features/autosave.js"></script>
    {/if}
{/block}

{block content}
    {var $tabs = [
        [
            'url' => '/apps?act=list',
            'title' => 'all_apps',
            'active' => false,
            'id' => 'apps_tab_list'
        ],
        [
            'url' => '/apps?act=installed',
            'title' => 'installed_apps',
            'active' => false,
            'id' => 'apps_tab_installed'
        ],
        [
            'url' => '/apps?act=dev',
            'title' => 'own_apps',
            'active' => true,
            'id' => 'apps_tab_dev'
        ]
    ]}
    {include "../components/page_tabs_header.latte", tabs => $tabs, id => 'apps_top_tabs', extra => '<a class="side_link" href="/app' . $id  . '">' . $name . '</a>'}
    <div class="page_block page_padding">
        <div class="form_group label_end game_edit">
            <form method="POST" enctype="multipart/form-data"{if !$create} data-autosave="true"{/if}>
                <div class="form_field">
                    <div class="form_label">{_name}</div>
                    <div class="form_data">
                        <input type="text" name="name" value="{$name ?? ''}" />
                    </div>
                </div>
                <div class="form_field">
                    <div class="form_label">{_description}</div>
                    <div class="form_data">
                        <input type="text" name="desc" value="{$desc ?? ''}" />
                    </div>
                </div>
                <div class="form_field">
                    <div class="form_label">{_avatar}</div>
                    <div class="form_data">
                        <input type="file" name="ava" accept="image/*" />
                    </div>
                </div>
                <div class="form_field">
                    <div class="form_label">{_app_news}</div>
                    <div class="form_data">
                        <input type="text" name="note" placeholder="{ovk_scheme(true) . $_SERVER['HTTP_HOST']}/note{$thisUser->getId()}_10" value="{$note ?? ''}" />
                    </div>
                </div>
                <div class="form_field">
                    <div class="form_label">URL</div>
                    <div class="form_data">
                        <input type="text" name="url" id="appUrlInput" value="{$url ?? ''}" />
                    </div>
                </div>
                <div class="form_field">
                    <div class="form_label">{_app_state}</div>
                    <div class="form_data">
                        <label class="checkbox"><input type="checkbox" name="enable" n:attr="checked => ($on ?? false)" /><span>{_app_enabled}</span></label>
                    </div>
                </div>
                {if $create}
                    <div class="settings_save_footer">
                        <input type="hidden" name="hash" value="{$csrfToken}" />
                        <input type="submit" value="{_create}" class="button" />
                    </div>
                {else}
                    <input type="hidden" name="hash" value="{$csrfToken}" />
                {/if}
            </form>
            {if !$create}
                <div class="information">
                    <ul>
                        <li>{tr("app_balance", $coins)|noescape} (<a href="javascript:withdraw({$id})">{_app_withdrawal_q}</a>)</li>
                        <li>{tr("app_users", $users)|noescape}</li>
                    </ul>
                </div>
            {/if}
        </div>
    </div>

    <script>
        window.coins = {$coins};

        {if $create}
        (function initAppUrlInfoTooltip() {
            const urlInput = document.getElementById('appUrlInput');
            if (!urlInput || urlInput.dataset.urlInfoBound) return;
            urlInput.dataset.urlInfoBound = '1';

            tippy(urlInput, {
                theme: 'light vk',
                placement: 'right-start',
                trigger: 'focus',
                interactive: true,
                interactiveBorder: 8,
                appendTo: 'parent',
                animation: 'left_right',
                duration: [100, 100],
                offset: [0, 8],
                allowHTML: true,
                content: {=(json_encode(tr('app_creation_hint_url') . '<br><br>' . tr('app_creation_hint_iframe')))|noescape}
            });
        })();
        {/if}
    </script>
{/block}
