{extends "../@layout.latte"}

{block title}
    {_playlist}
    {$playlist->getName()}
{/block}

{block headIncludes}
    <meta property="og:type" content="music.album">
    <meta property="og:title" content="{$playlist->getName()}">
    <meta property="og:url" content="{$playlist->getURL()}">
    <meta property="og:description" content="{$playlist->getDescription()}">
    <meta property="og:image" content="{$cover_url}">
    
    <script type="application/ld+json">
        {
            "@context": "http://schema.org/",
            "type": "MusicAlbum",
            "name": {$playlist->getName()},
            "url": {$playlist->getURL()}
        }
    </script>
    <link rel="stylesheet" href="/themepack/{$theme->getId()}/{$theme->getVersion()}/resource/css/playlist.css" data-vkify-route-style="playlist" />
{/block}

{block content}
    <div class="page_block">
        {include "bigplayer.latte"}
    </div>
    <script>
        window.__current_page_audio_context = {
            name: 'playlist_context',
            entity_id: {$playlist->getId()},
            page: {$page}
        }
    </script>
    <div class="_playlist_page_content_block">
        {include "../components/page_crumb_header.latte", crumbs: [
            ['href' => $owner->getURL(), 'title' => $owner->getCanonicalName()],
            ['href' => "/playlists{$ownerId}", 'title' => tr("playlists")],
            ['title' => tr("playlist")]
        ]}

        <div class="AudioPlaylistSnippet">
            <div class="AudioPlaylistSnippet__left">
                <div class="AudioPlaylistSnippet__covers">
                    {if $cover}
                        <a href="{$cover_url}" target="_blank" onclick="OpenMiniature(event, {$cover_url}, null, {$cover->getPrettyId()}, null); return false;">
                            <div class="AudioPlaylistSnippet__cover" style="background-image: url('{$cover_url}');"></div>
                        </a>
                    {else}
                        <div class="AudioPlaylistSnippet__cover" style="background-image: url('{$cover_url}');"></div>
                    {/if}
                    <div class="AudioPlaylistSnippet__play"></div>
                    <div class="AudioPlaylistSnippet__stop"></div>
                </div>
                <div class="AudioPlaylistSnippet__info">
                    {tr("audios_count", $count)}
                </div>
            </div>

            <div class="AudioPlaylistSnippet__right">
                <div class="AudioPlaylistSnippet__header">
                    <div class="AudioPlaylistSnippet__title">
                        <h1 class="AudioPlaylistSnippet__title--main">{$playlist->getName()}</h1>
                    </div>
                    <div class="AudioPlaylistSnippet__author">
                        <a href="{$playlist->getOwner()->getURL()}">{$playlist->getOwner()->getCanonicalName()}</a>
                    </div>
                    <div class="AudioPlaylistSnippet__info">
                        <span id='listensCount'>{tr("listens_count", $playlist->getListens())}</span>
                        {if $playlist->getEditTime()}
                            · {tr("updated_playlist")} {$playlist->getEditTime()}
                        {else}
                            · {tr("created_playlist")} {$playlist->getPublicationTime()}
                        {/if}
                    </div>
                </div>

                <div class="AudioPlaylistSnippet__description" n:if="$playlist->getDescription()">
                    {nl2br($playlist->getDescriptionHTML())|noescape}
                </div>

                <div class="AudioPlaylistSnippet__actions">
                    {ifset $thisUser}
                        <button class="AudioPlaylistSnippet__actionButton ActionButton--add {if $isBookmarked}ActionButton--add--added{/if}" id="{if $isBookmarked}unbookmarkPlaylist{else}bookmarkPlaylist{/if}" data-id="{$playlist->getId()}">
                            <span class="ActionButton--add__text">{if $isBookmarked}{_unbookmark}{else}{_bookmark}{/if}</span>
                        </button>
                        <button class="AudioPlaylistSnippet__actionButton ActionButton--share" onclick="shareAudioPlaylist(event, {$playlist->getOwner()->getId()}, {$playlist->getId()}); event.preventDefault(); event.stopPropagation(); return false;">
                            <span class="ActionButton--share__text">{_share}</span>
                        </button>
                        <button class="AudioPlaylistSnippet__actionButton ActionButton--more" id="playlist_more_actions_trigger" data-tippy-content-id="playlist_more_actions_menu" data-tippy-placement="bottom-end" n:if="$canEdit">
                            <span class="ActionButton--more__text">{_show_more}</span>
                        </button>
                        <div id="playlist_more_actions_menu" class="tippy-menu tippy-content-template" n:if="$canEdit">
                            <a class="tippy-menu-item" href="/playlist{$playlist->getPrettyId()}/edit" onclick="return showEditPlaylistModal({$playlist->getPrettyId()}, event);">{_edit_playlist}</a>
                            <a class="tippy-menu-item" href="/player/upload?playlist={$playlist->getId()}">{_upload_audio}</a>
                            <a class="tippy-menu-item" id="_deletePlaylist" data-id="{$playlist->getId()}">{tr('delete_playlist', 'Delete playlist')}</a>
                        </div>
                    {/ifset}
                </div>

                <div class="AudioPlaylistSnippet__body">
                    <button n:if="$count >= 1" class="AudioPlaylistSnippet__actionButton ActionButton--shuffle" id="playlistShuffleBtn">
                        <span class="ActionButton--shuffle__text"><vkifyloc name="shuffle_all" fallback="shuffle_tip"></vkifyloc></span>
                    </button>

                    <div class="AudioPlaylistSnippet__list audiosContainer scroll_container infContainer">
                        {if $count < 1}
                            {include "../components/content_error.latte", icon => "no_music.svg", description => tr("empty_playlist")}
                        {else}  
                            <div class="AudioPlaylistSnippet__audioRow scroll_node" n:foreach="$audios as $audio">
                                {include "player.latte", audio => $audio}
                            </div>

                            {include "../components/paginator.latte", conf => (object) [
                                "page"     => $page,
                                "count"    => $count,
                                "amount"   => sizeof($audios),
                                "perPage"  => $perPage ?? \OPENVK_DEFAULT_PER_PAGE,
                                "atBottom" => true,
                                'tidy'     => true
                            ]}
                        {/if}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            function updateCoversState() {
                const covers = document.querySelector('.AudioPlaylistSnippet__covers');
                if (!covers) return;
                const isCurrentPlaylist = window.player && window.player.context && window.player.context.object &&
                    (window.player.context.object.url === window.location.pathname || 
                     window.player.context.object.id === window.__current_page_audio_context.entity_id);
                const isPlaying = isCurrentPlaylist && window.player.audioPlayer && !window.player.audioPlayer.paused;
                covers.classList.toggle('AudioPlaylistSnippet__covers--playing', isPlaying);
            }

            function bindPlayerEvents() {
                if (window.player && window.player.audioPlayer) {
                    window.player.audioPlayer.removeEventListener('play', updateCoversState);
                    window.player.audioPlayer.removeEventListener('pause', updateCoversState);
                    window.player.audioPlayer.addEventListener('play', updateCoversState);
                    window.player.audioPlayer.addEventListener('pause', updateCoversState);
                    updateCoversState();
                } else {
                    setTimeout(bindPlayerEvents, 500);
                }
            }

            document.addEventListener('click', async function(e) {
                if (e.target.closest('.AudioPlaylistSnippet__play')) {
                    const isCurrentPlaylist = window.player && window.player.context && window.player.context.object &&
                        (window.player.context.object.url === window.location.pathname || 
                         window.player.context.object.id === window.__current_page_audio_context.entity_id);
                    if (isCurrentPlaylist) {
                        window.player.play();
                    } else {
                        const firstPlayBtn = document.querySelector('.audiosContainer .audioEmbed .playerButton .playIcon');
                        if (firstPlayBtn) firstPlayBtn.click();
                    }
                    setTimeout(updateCoversState, 100);
                }

                if (e.target.closest('.AudioPlaylistSnippet__stop')) {
                    if (window.player) window.player.pause();
                    setTimeout(updateCoversState, 100);
                }

                if (e.target.closest('#playlistShuffleBtn')) {
                    e.preventDefault();
                    if (!window.player) return;
                    const isCurrentPlaylist = window.player.context && window.player.context.object &&
                        (window.player.context.object.url === window.location.pathname || 
                         window.player.context.object.id === window.__current_page_audio_context.entity_id);
                    if (isCurrentPlaylist) {
                        await window.player.shuffle();
                    } else {
                        window.player.__renewContext();
                        await window.player.loadContext(window.__current_page_audio_context.page ?? 1);
                        await window.player.shuffle();
                    }
                    setTimeout(updateCoversState, 100);
                }
            });

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', bindPlayerEvents);
            } else {
                bindPlayerEvents();
            }
        })();
    </script>
{/block}
