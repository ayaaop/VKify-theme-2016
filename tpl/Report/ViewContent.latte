{block ViewContent}
    <div style="margin-block: 15px">
        {if $type == "post"}
            {include "../components/post.latte",
                post => $object,
                forceNoDeleteLink => true,
                forceNoPinLink => true,
                forceNoCommentsLink => true,
                forceNoShareLink => true,
                forceNoLike => true
            }
        {elseif $type == "photo"}
            {include "./content/photo.latte", photo => $object}
        {elseif $type == "video"}
            {include "./content/video.latte", video => $object}
        {elseif $type == "group" || $type == "user"}
            {include "../components/group.latte", group => $object, isUser => $type == "user"}
        {elseif $type == "comment"}
            {include "../components/comment.latte", comment => $object, timeOnly => true, correctLink => true}
        {elseif $type == "note"}
            {include "../components/notepost.latte",
                note => $object,
                forceNoDeleteLink => true,
                forceNoPinLink => true,
                forceNoCommentsLink => true,
                forceNoShareLink => true,
                forceNoLike => true
            }
        {elseif $type == "app"}
            {include "./content/app.latte", app => $object}
        {elseif $type == "audio"}
            {include "../Audio/player.latte", audio => $object}
        {elseif $type == "doc"}
            {include "../Documents/components/doc.latte", doc => $object}
        {else}
            {include "../components/content_error.latte", title => tr("no_data"), description => tr("version_incompatibility")}
        {/if}
    </div>
{/block}
