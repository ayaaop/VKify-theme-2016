{block content}
    <div class="search_row" style="padding: 0">
        <div class="img">
            <a href="/app{$app->getId()}">
                <img src="{if str_contains($app->getAvatarUrl(), 'camera_200.png')}/themepack/vkify16/{$theme->getVersion()}/resource/camera_200.png{else}{$app->getAvatarUrl()}{/if}" />
            </a>
        </div>
        <div class="info">
            <div class="labeled name">
                <a href="/app{$app->getId()}">
                    <b>{$app->getName()}</b>
                </a>
            </div>
            <div class="labeled">
                {$app->getDescription()}
            </div>
        </div>
    </div>
{/block}