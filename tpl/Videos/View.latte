{extends "../@layout.latte"}

{block title}{_video}{/block}

{block content}
    <div class='page_block'>
        {include "../components/page_crumb_header.latte", crumbs: [
            ['href' => $user->getURL(), 'title' => $user->getCanonicalName()],
            ['href' => "/videos{$user->getId()}", 'title' => tr("videos")],
            ['title' => $video->getName()]
        ]}
        <div class="video_block_layout" style="padding-top: 20px;">
            {if $video->getType() === 0}
                <div class="bsdn" data-name="{$video->getName()}" data-author="{$user->getCanonicalName()}">
                    <video src="{$video->getURL()}"></video>
                </div>
            {else}
                {var $driver = $video->getVideoDriver()}
                {if !$driver}
                    {_unknown_video}
                {else}
                    {$driver->getEmbed()|noescape}
                {/if}
            {/if}
        </div>
        <div class="video_info">
            <div class='video_info_title'>
                {$video->getName()}
            </div>
            <div class="video_info_actions">
                {if isset($thisUser)}
                    {if $thisUser->getId() != $video->getOwner()->getId()}
                        {var $canReport = true}
                    {/if}
                    {var $liked = $video->hasLikeFrom($thisUser)}
                    {var $likesCount = $video->getLikesCount()}
                    <a href="/video{$video->getPrettyId()}/like?hash={rawurlencode($csrfToken)}" class="video_like_button button video_like_wrap" data-liked="{(int) $liked}" data-likes="{$likesCount}" data-id="{$video->getPrettyId()}" data-type='video'>
                        <i class="action_icon" id="{if $liked}liked{/if}"></i>
                        <span class="action_label">{tr('mobile_like')}</span>
                        <span class="action_count">{if $likesCount > 0}{$likesCount}{/if}</span>
                    </a>
                    <a onclick="javascript:repost({$video->getPrettyId()}, 'video')" class="video_share_button button button_light">
                        <i class="action_icon"></i>
                        <span class="action_label">{tr('share')}</span>
                    </a>
                    <span class="video_info_more_actions" data-tippy-content-id="videoMoreActionsTooltip">
                        <div class="button button_light _more_wrap">{_show_more}</div>
                        <div id="videoMoreActionsTooltip" class="tippy-menu tippy-content-template">
                            <a href="javascript:showEditVideoModal('{$video->getPrettyId()}')">
                                {tr('edit')}
                            </a>
                            <a n:if="$thisUser->getId() === $video->getOwner()->getId()" href="/video{$video->getPrettyId()}/remove">
                                {tr('delete')}
                            </a>
                            <a n:if="$canReport ?? false" href="javascript:reportVideo({$video->getId()})">
                                {tr('report')}
                            </a>
                            <a n:if="$video->getType() == 0" href="{$video->getURL()}" download="">
                                {tr('download_video')}
                            </a>
                        </div>
                    </span>
                {/if}
            </div>
            <div class="video_info_author clear_fix">
                <a href="{$video->getOwner()->getURL()}" class="video_info_author_image">
                    <img class="post-avatar" src="{$video->getOwner()->getAvatarUrl('miniscule')}" />
                </a>
                <div class="video_info_author_info">
                    <div class="video_info_author_name">
                        <a href="{$video->getOwner()->getURL()}">{$video->getOwner()->getCanonicalName()}</a>
                    </div>
                    <div class="video_info_author_date">
                        {$video->getPublicationTime()}
                    </div>
                </div>
            </div>
            <div class="video_info_description" n:if="$video->getDescription()">
                {var $videoDesc = $video->getDescription($html = false)}
                {var $bigText = strlen($videoDesc) > 500}
                {if $bigText}
                    <span class="truncated_text">{$videoDesc|truncate:500|noescape}</span>
                    <span class="full_text hidden">{$video->getDescription()}</span>
                    <a href="javascript:void(0)" class="collapse_button" onclick="javascript:expandText(this)">{_show_more}</a>
                {else}
                    {$video->getDescription()}
                {/if}
            </div>
        </div>
        <div class="clear_fix video_comments">
            {include "../components/comments.latte",
                    comments => $comments,
                    count => $cCount,
                    page => $cPage,
                    model => "videos",
                    parent => $video}
        </div>
    </div>
{/block}
