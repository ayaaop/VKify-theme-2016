{var $author = $comment->getOwner()}
{var $Club  = openvk\Web\Models\Entities\Club::class}
{var $likesCount = $comment->getLikesCount()}
{var $target = $comment->getTarget()}
{var $postId = $target instanceof \openvk\Web\Models\Entities\Post ? $target->getId() : NULL}
{var $correctLink = $correctLink ?? true}
<div data-id="1_{$comment->getId()}" class="post reply scroll_node" data-uniqueid="reply_{$comment->getId()}" id="_comment{$comment->getId()}" data-comment-id="{$comment->getId()}" data-owner-id="{$author->getId()}" data-from-group="{$author instanceof $Club ? 'true' : 'false'}" n:attr="data-post-id => $postId">
    <div class="reply_wrap">
        <a class="reply_image{if !$author instanceof $Club && $author->isOnline()} online{/if}" href="{$author->getURL()}">
            {include 'avatar.latte', author => $author, size => 'miniscule', width => 30, class => 'reply_img'}
        </a>
        <div class="reply_content">
            <div class="fl_r reply_actions_wrap">
                <div class="reply_actions" n:if="isset($thisUser)">
                    <a n:if="$comment->canBeEditedBy($thisUser)" class="reply_action reply_edit_action" id="editPost" data-id="{$comment->getId()}" data-tip="simple-black" data-tiptitle="{_edit}"></a>
                    <a n:if="$comment->canBeDeletedBy($thisUser)" class="reply_action reply_delete_action" href="/comment{$comment->getId()}/delete" data-tip="simple-black" data-tiptitle="{_delete}"></a>
                    <a n:if="$thisUser->getId() != $author->getRealId()" class="reply_action reply_report_action" href="javascript:reportComment({$comment->getId()})" data-tip="simple-black" data-tiptitle="{_report}"></a>
                </div>
            </div>
            <div class="reply_author post-author">
                <a class="author" href="{$author->getURL()}">
                    <b class="post-author-name">{$author->getCanonicalName()}</b>
                </a>
                <a class="page_verified" n:if="$author->isVerified()" href="/verify"></a>
            </div>
            <div class="post-content" id="{$comment->getId()}">
                <div class="text reply_text" id="text{$comment->getId()}">
                    {include "truncated_text.latte", html => $comment->getText(), plain => $comment->getText(false), limit => 500}

                    {var $attachmentWidth = 180}
                    {var $attachmentsLayout = $comment->getChildrenWithLayout($attachmentWidth)}
                    <div n:ifcontent class="attachments attachments_b" style="height: {$attachmentsLayout->height|noescape}; width: {$attachmentsLayout->width|noescape};">
                        <div class="attachment" n:foreach="$attachmentsLayout->tiles as $attachment" style="float: {$attachment[3]|noescape}; width: {$attachment[0]|noescape}; height: {$attachment[1]|noescape};" data-localized-nsfw-text="{_nsfw_warning}">
                            {include "attachment.latte", attachment => $attachment[2], parent => $comment, parentType => "comment", tilesCount => sizeof($attachmentsLayout->tiles)}
                        </div>
                    </div>

                    <div n:ifcontent class="attachments attachments_m">
                        <div class="attachment" n:foreach="$attachmentsLayout->extras as $attachment" n:if="!($attachment instanceof \openvk\Web\Models\Entities\Audio)">
                            {include "attachment.latte", attachment => $attachment, post => $comment}
                        </div>
                        <div class="attachment" n:foreach="$attachmentsLayout->extras as $attachment" n:if="$attachment instanceof \openvk\Web\Models\Entities\Audio">
                            {include "attachment.latte", attachment => $attachment, post => $comment}
                        </div>
                    </div>
                </div>
            </div>
            <div class='post_edit'></div>
            <div class="reply_footer clear_fix" n:if="!($timeOnly ?? false)">
                {if isset($thisUser)}
                    {var $isLiked = $comment->hasLikeFrom($thisUser)}
                    <a class="post_like like_wrap {if $isLiked}my_like{/if}" href="/comment{$comment->getId()}/like?hash={rawurlencode($csrfToken)}" data-likes='{$likesCount}' data-id="1_{$comment->getPrettyId()}" data-type='comment'>
                        <i class="action_icon" id="{if $isLiked}liked{/if}"></i>
                        <span class="action_count">{if $likesCount > 0}{$likesCount}{/if}</span>
                    </a>
                {/if}
                <div class="reply_date">
                    <a href="{if $correctLink}{$comment->getTargetURL()}{/if}#_comment{$comment->getId()}" class="reply_link">
                        {$comment->getPublicationTime()}
                        <span n:if="$comment->getEditTime()" class="edited editedMark">({_edited_short})</span>
                    </a>
                </div>
                <div n:if="isset($thisUser)" class="reply_link_wrap">
                    <a n:if="!($no_reply_button ?? false)" class="comment-reply reply_link">
                        {_reply}
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
