{*
 * Content error component
 * 
 * Displays an error message with an optional icon, title and description
 * 
 * @param bool|string|null $icon     - Path to icon image, false to hide icon, null/undefined for default
 * @param string|null      $title    - Error title text (optional)
 * @param string           $description - Error description text
 *}

{var $icon = $icon ?? 'no_posts.png'}
{var $title = $title ?? null}
{var $description = $description ?? ''}

<div class='content_page_error'>
    <img n:if="$icon !== false" class="icon" src="/themepack/vkify16/{$theme->getVersion()}/resource/icons/{$icon}" alt="{$description ?: 'Error'}" loading="lazy"/>
    <span class="text">
        <b n:if="$title">{$title|noescape}</b>
        <div class="description">
            {$description|noescape}
        </div>
    </span>
</div>
