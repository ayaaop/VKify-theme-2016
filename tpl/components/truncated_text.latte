{var $html = $html ?? ''}
{var $plain = $plain ?? strip_tags(html_entity_decode($html, ENT_QUOTES, 'UTF-8'))}
{var $limit = $limit ?? 500}
{var $lineLimit = $lineLimit ?? 9999}
{var $isEditable = $isEditable ?? false}
{var $editUrl = $editUrl ?? ''}
{var $editClass = $editClass ?? 'pv_can_edit'}
{var $textClass = $textClass ?? ''}

{php
if (!function_exists('vkify_truncate_html')) {
    function vkify_truncate_html($html, $limit, $lineLimit = 9999, $inlineAppend = '') {
        if (mb_strlen(strip_tags(html_entity_decode($html, ENT_QUOTES, 'UTF-8'))) <= $limit) {
            return $html;
        }

        preg_match_all('/<[^>]+>|&[^;\s]{1,9};|./us', $html, $tokens);
        
        $result = '';
        $printed = 0;
        $lines = 1;
        $tags = [];
        $truncated = false;

        foreach ($tokens[0] as $t) {
            if ($printed >= $limit) {
                $truncated = true;
                break;
            }

            if (str_starts_with($t, '<')) { // Handle HTML tags
                if (preg_match('%^<\s*br\s*/?>%i', $t) && $lines++ >= $lineLimit) {
                    $truncated = true;
                    break;
                }
                
                $result .= $t;
                
                if (preg_match('%^</\s*([a-z0-9]+)>%i', $t)) {
                    array_pop($tags); // Close tag
                } elseif (preg_match('%^<\s*([a-z0-9]+)%i', $t, $m)) {
                    $tagName = strtolower($m[1]);
                    if (!in_array($tagName, ['br', 'img', 'hr', 'input', 'meta', 'link'])) {
                        $tags[] = $tagName;
                    }
                }
            } else {
                if ($t === "\n" && $lines++ >= $lineLimit) {
                    $truncated = true;
                    break;
                }
                $result .= $t;
                $printed++;
            }
        }

        if ($truncated) {
            $result .= '…';
        }

        $result .= $inlineAppend;

        while ($tag = array_pop($tags)) {
            $result .= "</$tag>";
        }

        return $result;
    }
}
}

{var $bigText = mb_strlen($plain) > $limit || substr_count($plain, "\n") + 1 > $lineLimit}

{if $html}
    {if $isEditable}
        <a class="{$editClass}" href="{$editUrl|noescape}">
            {if $bigText}
                <span class="truncated_text really_text {$textClass}">
                    {vkify_truncate_html($html, $limit, $lineLimit, " <span class='collapse_button' onclick='event.stopPropagation(); event.preventDefault(); expandText(this)'>" . tr('show_more') . "</span>")|noescape}
                </span>
                <span class="full_text hidden really_text {$textClass}">
                    {$html|noescape}
                    <span class="collapse_button" onclick="event.stopPropagation(); event.preventDefault(); expandText(this)">{_show_less}</span>
                </span>
            {else}
                <span class="really_text {$textClass}">{$html|noescape}</span>
            {/if}
        </a>
    {else}
        {if $bigText}
            <span class="truncated_text really_text {$textClass}">
                {vkify_truncate_html($html, $limit, $lineLimit, " <a href='javascript:void(0)' class='collapse_button' onclick='javascript:event.preventDefault(); expandText(this)'>" . tr('show_more') . "</a>")|noescape}
            </span>
            <span class="full_text hidden really_text {$textClass}">
                {$html|noescape}
                <a href="javascript:void(0)" class="collapse_button" onclick="javascript:event.preventDefault(); expandText(this)">{_show_less}</a>
            </span>
        {else}
            <span class="really_text {$textClass}">
                {$html|noescape}
            </span>
        {/if}
    {/if}
{/if}
