{capture $wallSearchExtra}
<div class="ui_tabs_right_section">
    <div class="ui_tab_search_wrap ui_tab_item">
        <a class="ui_tab_plain ui_tab_search" href="/wall{$owner}?type=search">
        </a>
        {include "search_bar.latte",
            id => 'wall_search',
            form_id => 'wall_search_form',
            action => "/wall{$owner}",
            input_name => 'q',
            hidden_fields => ['type' => 'search'],
            class => '_wrap ui_search_old'}
    </div>
</div>
{/capture}

{var $allCount = $type == 'all' ? $count : (new \openvk\Web\Models\Repositories\Posts())->getPostCountOnUserWall($owner)}
{var $ownersCount = $type == 'owners' ? $count : (new \openvk\Web\Models\Repositories\Posts())->getOwnersCountOnUserWall($owner)}
{var $tabs = [
    [
        'url' => "/wall{$owner}",
        'title' => 'all_posts',
        'active' => $type == 'all',
        'id' => 'wall_tab_all',
        'count' => $allCount
    ],
    [
        'url' => "/wall{$owner}?type=owners",
        'title' => isset($club) ? "clubs_posts" : tr("users_posts", ovk_proc_strtr($oObj->getFirstName(), 20)),
        'active' => $type == 'owners',
        'id' => 'wall_tab_owners',
        'count' => $ownersCount,
        'translate' => isset($club) ? true : false,
    ]
]}

{ifset $club}
    {if isset($thisUser) && $club->getWallType() == 2}
        {var $suggestedWallCount = $club->getSuggestedPostsCount($thisUser) ?? 0}
        {if $suggestedWallCount > 0}
            {var $tabs = array_merge($tabs, [[
                'url' => "/club{$club->getId()}/suggested",
                'title' => 'suggested',
                'active' => false,
                'id' => 'wall_tab_suggested',
                'count' => $suggestedWallCount
            ]])}
        {/if}
    {/if}
{/ifset}

{var $wallPostPlaceholder = null}
{ifset $club}
    {if isset($thisUser) && $club->getWallType() == 2 && !$club->canBeModifiedBy($thisUser)}
        {var $wallPostPlaceholder = tr("suggest_new")}
    {/if}
{/ifset}
<div class="wall_module">
    <div n:if="$canPost" class="page_block">
        {include "../components/textArea.latte", route => "/wall$owner/makePost", graffiti => true, polls => true, notes => true, hasSource => true, geo => true, docs => true, placeholder => $wallPostPlaceholder}
    </div>
    <div class="page_block wall_posts_tabs">
        {include "../components/page_tabs_header.latte", tabs => $tabs, id => 'wall_top_tabs', white => true, extra => $wallSearchExtra}
    </div>
    <div class="insertThere" id="postz"></div>
    <div id="underHeader">
        <div class="wall_posts content scroll_container">
            {if sizeof($posts) > 0}
                {foreach $posts as $post}
                    {continueIf isset($club) && $post->isPinned()}
                    {include "../components/post.latte", post => $post, commentSection => true, onWallOf => true}
                {/foreach}
                {include "../components/paginator.latte", conf => $paginatorConf}
            {else}
				<div class="page_block">
					{include "../components/content_error.latte", description => tr("no_posts_abstract")}
				</div>
            {/if}
        </div>
    </div>
</div>